[sub_resource type="GDScript" id="GDScript_6igcf"]
resource_name = "Movment"
script/source = "extends CharacterBody2D

const GRAVITY = 800
const SPEED = 100
const JUMP_FORCE = -250

var elapsed_time: float = 0.0
var timer_started: bool = false
var timer_stopped: bool = false
var start_position: Vector2
var db

@onready var timer_label = $TimerLabel


func _ready():
	start_position = global_position
	timer_label.text = \"Zeit: 0.00\"

	db = SQLite.new()
	db.path = \"user://jump_run.db\"

	if db.open_db():
		print(\"Datenbank verbunden\")
		create_table()
	else:
		print(\"Datenbank Fehler\")


func create_table():
	var sql = \"CREATE TABLE IF NOT EXISTS scores (id INTEGER PRIMARY KEY AUTOINCREMENT, time REAL)\"
	db.query(sql)
	print(\"Tabelle erstellt oder bereits vorhanden\")


func save_time():
	var sql = \"INSERT INTO scores (time) VALUES (%f)\" % elapsed_time
	db.query(sql)
	print(\"Zeit gespeichert: \", elapsed_time)


func _physics_process(delta):
	# Schwerkraft
	if not is_on_floor():
		velocity.y += GRAVITY * delta
	else:
		velocity.y = 0

	# Bewegung
	velocity.x = 0
	if Input.is_action_pressed(\"left\"):
		velocity.x = -SPEED
	elif Input.is_action_pressed(\"right\"):
		velocity.x = SPEED

	# Springen
	if Input.is_action_just_pressed(\"jump\") and is_on_floor():
		velocity.y = JUMP_FORCE

	move_and_slide()

	# Timer startet sobald sich der Player bewegt
	if not timer_started and abs(velocity.x) > 0:
		timer_started = true

	# Timer läuft solange Ziel nicht erreicht wurde
	if timer_started and not timer_stopped:
		elapsed_time += delta
		timer_label.text = \"Zeit: %.2f\" % elapsed_time

	# Respawn wenn man runterfällt
	if global_position.y > 1000:
		respawn()


func respawn():
	global_position = start_position
	velocity = Vector2.ZERO


func _on_goal_line_body_entered(body: Node2D) -> void:
	if body == self:
		timer_stopped = true
		timer_label.text = \"Endzeit: %.2f\" % elapsed_time
		save_time()
"

